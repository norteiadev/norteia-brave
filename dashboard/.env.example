# Dashboard BFF environment (D-02). Copy to .env.local for local dev.
# NONE of these are exposed to the browser — they are read only inside the
# server-side Route Handlers (app/api/[...path]/route.ts).

# FastAPI base URL the BFF proxies to (server-side only).
BRAVE_API_URL=http://localhost:8000

# The server-held service token the BFF injects when calling FastAPI.
# Mirrors the FastAPI Bearer gate from plan 04-01 (BRAVE_DASHBOARD_BEARER_TOKEN
# on the backend). NEVER shipped to the browser.
BRAVE_DASHBOARD_BEARER_TOKEN=change-me-service-token

# The operator token the browser presents to the BFF. The BFF validates the
# browser's Authorization: Bearer against this (constant-time) before forwarding.
# Single shared operator token this milestone (multi-user/RBAC deferred).
DASHBOARD_OPERATOR_TOKEN=change-me-operator-token
