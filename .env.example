# Database (psycopg 3 URL format)
BRAVE_DB_URL=postgresql+psycopg://brave:brave@localhost:5432/norteia_brave

# Redis
BRAVE_REDIS_URL=redis://localhost:6379/0

# LLM — OpenRouter (DeepSeek backend)
BRAVE_LLM_OPENROUTER_API_KEY=your_openrouter_key_here
BRAVE_LLM_DEEPSEEK_PRIMARY_SLUG=deepseek/deepseek-chat

# LLM — Anthropic (Claude Sonnet; Phase 3 WhatsApp)
BRAVE_LLM_ANTHROPIC_API_KEY=your_anthropic_key_here

# Norteia API (service token for Mar push)
BRAVE_NORTEIA_API_SERVICE_TOKEN=your_service_token_here
BRAVE_NORTEIA_API_BASE_URL=https://api.norteia.com

# Score versioning
BRAVE_SCORE_VERSION=v1.0

# Feature flags
# Set to 1 to allow real external API calls (disabled in CI / offline suite)
RUN_REAL_EXTERNALS=0
